rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: gallery
    // Document ID: auto-generated or numeric id
    // Fields: id (number), titleEn (string), titleRu (string), captionEn (string), captionRu (string), url (string), sectionEn (string), sectionRu (string), order (number)
    //
    // Collection: config
    // Document: mainImages
    // Fields: homeHero (string), bioPortrait (string), relationshipsHero (string), extraSyndrome (string)
    //
    // Document: settings
    // Fields: dashboardPassword (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "suxa6462@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Gallery Rules
    match /gallery/{itemId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admin can edit
    }

    // Config Rules
    match /config/{docId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admin can edit
    }
  }
}
